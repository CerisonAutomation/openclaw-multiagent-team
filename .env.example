# ─────────────────────────────────────────────────────────────────────────────
# openclaw + inspector environment config
# Copy to .env and fill in what you have.  Leave blank = not used.
# ─────────────────────────────────────────────────────────────────────────────

# ── Jan (your local Jan app) ──────────────────────────────────────────────────
# Jan runs at 127.0.0.1:1337 by default — leave this as-is unless you changed it.
JAN_BASE=http://127.0.0.1:1337/v1

# Your loaded Jan model ID — copy it exactly from Jan's settings screen.
# Example: Qwen3_5-9B-Uncensored-HauhauCS-Aggressive-Q4_K_M
JAN_MODEL=Qwen3_5-9B-Uncensored-HauhauCS-Aggressive-Q4_K_M

# ── Ollama (optional — if you also use Ollama) ────────────────────────────────
# Ollama is tried first; Jan is the fallback. Remove if you only use Jan.
OLLAMA_BASE=http://localhost:11434
OLLAMA_TIMEOUT=120

# ── Inspector server ──────────────────────────────────────────────────────────
INSPECTOR_HOST=0.0.0.0
INSPECTOR_PORT=8765

# ── Cloud providers (optional — only needed for cloud routes) ─────────────────
# OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
